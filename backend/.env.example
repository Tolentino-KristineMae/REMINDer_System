APP_NAME=Laravel
APP_ENV=local
# Required in production (e.g. Render). Generate: php artisan key:generate --show
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local: sqlite | Production (Supabase Postgres on Render): pgsql + DATABASE_URL
DB_CONNECTION=pgsql
DB_HOST=db.onkhvozgxedcsubgvrsf.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=public
DB_SSLMODE=require
# DB_URL=

# --- Supabase Postgres (Render) — copy "Connection string" URI from Supabase → Database ---
# DB_CONNECTION=pgsql
# DATABASE_URL=postgresql://postgres.[ref]:[X9fXhUtMu37dUyrM]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# DB_SSLMODE=require

# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# When the React app is on Vercel (or another domain), list allowed origins comma-separated.
# Example: https://remindersystem.vercel.app
# For all Vercel preview URLs, set CORS_ALLOW_VERCEL_PREVIEWS=true (or list each origin here).
# Omit or use * for wide-open dev only.
CORS_ALLOWED_ORIGINS=
# CORS_ALLOW_VERCEL_PREVIEWS=false
