# Copy to .env locally if you override defaults.
#
# --- Vercel (required when API is on Render or another host) ---
# Must include the `/api` prefix — Laravel mounts api.php under /api.
VITE_API_BASE_URL=https://your-backend.onrender.com/api
#
# Public files under Laravel storage/ (proof images, etc.) — origin only, no /api, no trailing path.
VITE_STORAGE_BASE_URL=https://your-backend.onrender.com
#
# --- Supabase (optional: for /deployment-status browser check) ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
# Use "anon" / "public" key from Supabase → Project Settings → API
VITE_SUPABASE_ANON_KEY=
# Or newer dashboard label:
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
